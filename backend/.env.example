DATABASE_URL="postgresql://postgres:postgres@postgres:5432/app_db"
OPENROUTER_API_KEY="your-openrouter-api-key"
# Optional. A direct Google AI Studio / Gemini API key (ai.google.dev), separate from anything
# routed through OpenRouter -- gives a DEDICATED per-project free quota (not shared with every
# other OpenRouter user hitting the same free model). Only used by chain entries prefixed
# "gemini-direct:" (see LLM_MODEL_CHAIN below); a "gemini-direct:" entry simply fails its one
# attempt and falls through to the next tier if this is left empty, same as any misconfigured tier.
GEMINI_API_KEY=""
# Ordered, comma-separated model slugs every LLM call falls back through -- one attempt per
# model, no same-model retry, cascades to the next on any failure. A "gemini-direct:" prefix
# routes that one entry to Google's own endpoint using GEMINI_API_KEY above instead of OpenRouter.
# Confirm every OpenRouter slug against https://openrouter.ai/api/v1/models before changing this,
# provider model strings aren't guessable and a wrong slug silently 404s that whole tier every
# single attempt. Last entry is the paid last-resort tier (logged at WARNING when reached).
LLM_MODEL_CHAIN="gemini-direct:gemini-flash-lite-latest,gemini-direct:gemini-flash-latest,google/gemma-4-31b-it:free,nvidia/nemotron-3-ultra-550b-a55b:free,openai/gpt-oss-20b:free,nvidia/nemotron-3-nano-30b-a3b:free,google/gemini-2.5-flash"
# Subset of the chain above that gets a validation + auto-fix pass before its output is trusted.
LLM_VALIDATED_MODELS="google/gemma-4-31b-it:free"
# Fast/free model used only to reformat a validated tier's malformed output -- never regenerates.
LLM_VALIDATION_FIX_MODEL="openai/gpt-oss-20b:free"
REDIS_URL="redis://redis:6379/0"

# Shared secret known only to the Next.js proxy and this service. Generate a real random
# value for local dev and a different one per environment -- never reuse across environments.
INTERNAL_AUTH_SECRET="change-me-generate-a-random-value"

ENVIRONMENT="development"

# --- Clerk (auth) ---
# From your Clerk dashboard's API Keys page. CLERK_JWT_KEY (the PEM public key, under
# API Keys -> Advanced -> JWT public key) is what makes session verification networkless -- a
# local signature check on every request instead of a round-trip to Clerk's API.
CLERK_SECRET_KEY="sk_test_your-secret-key"
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# --- Resend (export-delivery emails only -- Clerk handles all auth emails natively) ---
# From your Resend dashboard's API Keys page. Optional: the "Email to me" export feature 500s
# with a clear message if a send is attempted with this unset, but the rest of the app is
# unaffected.
RESEND_API_KEY=""

# --- Sentry (error tracking) ---
# Optional and inert until set: no real Sentry account/project exists for this app yet, so
# app/observability.py's init_sentry() simply never calls sentry_sdk.init() while this is empty
# -- no crash, no network calls, no behavior change. Once a real project exists, paste its DSN
# from Sentry -> Settings -> Projects -> <project> -> Client Keys (DSN).
SENTRY_DSN=""
