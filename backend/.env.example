DATABASE_URL="postgresql://postgres:postgres@postgres:5432/app_db"
OPENROUTER_API_KEY="your-openrouter-api-key"
# The OpenRouter model slug every LLM call in the backend uses -- confirm the exact slug against
# https://openrouter.ai/api/v1/models before changing this, provider model strings aren't
# guessable and a wrong slug fails every LLM call in the app. openai/gpt-oss-120b:free was
# evaluated as a free-tier swap-in and reverted after it failed architecture generation (the
# app's most JSON-complex call) in all end-to-end test attempts -- see git history.
LLM_MODEL="google/gemini-2.5-flash"
REDIS_URL="redis://redis:6379/0"

# Shared secret known only to the Next.js proxy and this service. Generate a real random
# value for local dev and a different one per environment -- never reuse across environments.
INTERNAL_AUTH_SECRET="change-me-generate-a-random-value"

ENVIRONMENT="development"
