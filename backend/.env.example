DATABASE_URL="postgresql://postgres:postgres@postgres:5432/app_db"
OPENROUTER_API_KEY="your-openrouter-api-key"
# Ordered, comma-separated OpenRouter model slugs every LLM call falls back through -- one
# attempt per model, no same-model retry, cascades to the next on any failure. Confirm every
# slug against https://openrouter.ai/api/v1/models before changing this, provider model strings
# aren't guessable and a wrong slug silently drops that whole tier. Last entry is the paid
# last-resort tier (logged at WARNING when reached).
LLM_MODEL_CHAIN="openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-ultra-550b-a55b:free,qwen/qwen3-coder:free,google/gemini-2.5-flash"
# Subset of the chain above that gets a validation + auto-fix pass before its output is trusted.
LLM_VALIDATED_MODELS="google/gemma-4-31b-it:free"
# Fast/free model used only to reformat a validated tier's malformed output -- never regenerates.
LLM_VALIDATION_FIX_MODEL="openai/gpt-oss-120b:free"
REDIS_URL="redis://redis:6379/0"

# Shared secret known only to the Next.js proxy and this service. Generate a real random
# value for local dev and a different one per environment -- never reuse across environments.
INTERNAL_AUTH_SECRET="change-me-generate-a-random-value"

ENVIRONMENT="development"
