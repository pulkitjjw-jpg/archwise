DATABASE_URL="postgresql://username:password@localhost:5432/database_name"
# WARNING: Replace with your own OpenRouter key before deployment. Do not reuse credentials from other workspaces.
OPENROUTER_API_KEY="your-openrouter-api-key"

# --- New backend split (see backend/) ---
# These two above (DATABASE_URL, OPENROUTER_API_KEY) are retired from the frontend once the
# migration to backend/ is complete -- they'll live only in backend/.env. Until the old
# src/app/api routes are deleted, both old and new vars are needed side by side.
BACKEND_URL="http://localhost:8000"
# Must match backend/.env's INTERNAL_AUTH_SECRET exactly.
INTERNAL_AUTH_SECRET="change-me-generate-a-random-value"

# --- Clerk (auth) ---
# From your Clerk dashboard's API Keys page. NEXT_PUBLIC_ prefix is required on the publishable
# key since Clerk's frontend SDK reads it client-side.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your-publishable-key"
CLERK_SECRET_KEY="sk_test_your-secret-key"

# --- Sentry (error tracking) ---
# Optional and inert until set: no real Sentry account/project exists for this app yet, so
# src/instrumentation-client.ts / sentry.server.config.ts / sentry.edge.config.ts never call
# Sentry.init() while this is empty -- no crash, no network calls, no behavior change. NEXT_PUBLIC_
# prefix is required (same reason as the Clerk key above): this is read both client-side and
# server-side, and gets inlined into the client bundle at BUILD time -- see the root Dockerfile's
# NEXT_PUBLIC_SENTRY_DSN build ARG for how that's threaded through the containerized build too.
NEXT_PUBLIC_SENTRY_DSN=""
# Optional, CI/build-time only -- only used for uploading source maps to Sentry for readable
# stack traces (see next.config.ts's withSentryConfig call, which is itself skipped entirely
# while NEXT_PUBLIC_SENTRY_DSN is unset). Not needed for local dev.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
